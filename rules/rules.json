  "rules": [
    {
      "id": "R-001",
      "text": "所有涉及 BTC 的回复必须引用 [[btc-allocation-strategy]] 和最新投委会纪要",
      "injection_points": [
        "email.analysis",
        "compose"
      ],
      "priority": 5,
      "source": "manual",
      "enabled": false,
      "created_at": "2026-04-22T00:00:00+08:00",
      "updated_at": "2026-04-22T15:36:58.066802+00:00"
    },
    {
      "id": "R-002",
      "text": "提到仓位时必须检查合规上限 ([[position-size-limits]])",
      "injection_points": [
        "email.analysis",
        "compose"
      ],
      "priority": 5,
      "source": "manual",
      "enabled": false,
      "created_at": "2026-04-22T00:00:00+08:00",
      "updated_at": "2026-04-22T15:39:13.013253+00:00"
    },
    {
      "id": "R-003",
      "text": "回复监管机构时必须引用具体法规编号",
