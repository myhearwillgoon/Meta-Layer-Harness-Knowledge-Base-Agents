        "email.analysis",
        "compose"
      ],
      "priority": 5,
      "source": "manual",
      "enabled": true,
      "created_at": "2026-04-22T00:00:00+08:00",
      "updated_at": "2026-04-22T00:00:00+08:00"
    },
    {
      "id": "R-004",
      "text": "涉及 LP 问询时，必须参考对应 LP 文件中的偏好和限制",
