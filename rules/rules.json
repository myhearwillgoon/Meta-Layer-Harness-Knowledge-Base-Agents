        "goals.review"
      ],
      "priority": 4,
      "source": "manual",
      "enabled": true,
      "created_at": "2026-04-22T00:00:00+08:00",
      "updated_at": "2026-04-22T00:00:00+08:00"
    },
    {
      "id": "R-010",
      "text": "目标重规划时必须评估对子目标的级联影响",
      "injection_points": [
        "goals.replan"
      ],
      "priority": 4,
      "source": "manual",
      "enabled": true,
      "created_at": "2026-04-22T00:00:00+08:00",
      "updated_at": "2026-04-22T00:00:00+08:00"
    },
    {
      "id": "R-011",
      "text": "QA 相关性判断时，优先匹配知识库中的策略和政策文件",
