        "email.call1"
      ],
      "priority": 5,
      "source": "manual",
      "enabled": true,
      "created_at": "2026-04-22T00:00:00+08:00",
      "updated_at": "2026-04-22T00:00:00+08:00"
    },
    {
      "id": "R-007",
      "text": "嵌入查询必须使用自然语言描述，避免关键词堆砌",
      "injection_points": [
        "email.embed",
        "qa.embed"
      ],
      "priority": 3,
      "source": "manual",
      "enabled": true,
      "created_at": "2026-04-22T00:00:00+08:00",
      "updated_at": "2026-04-22T00:00:00+08:00"
    },
    {
      "id": "R-008",
      "text": "目标创建时必须指定自主级别 (observe/draft/execute) 和负责人",
      "injection_points": [
        "goals.creation"
      ],
      "priority": 4,
      "source": "manual",
      "enabled": true,
      "created_at": "2026-04-22T00:00:00+08:00",
      "updated_at": "2026-04-22T00:00:00+08:00"
    },
    {
      "id": "R-009",
      "text": "目标审查时必须检查知识库相关条目是否有更新",
