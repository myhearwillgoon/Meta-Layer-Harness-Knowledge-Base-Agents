        "qa.relevance"
      ],
      "priority": 3,
      "source": "manual",
      "enabled": true,
      "created_at": "2026-04-22T00:00:00+08:00",
      "updated_at": "2026-04-22T00:00:00+08:00"
    },
    {
      "id": "R-012",
      "text": "QA 回答必须标注数据来源和置信度",
      "injection_points": [
        "qa.answer"
      ],
      "priority": 4,
      "source": "manual",
      "enabled": true,
      "created_at": "2026-04-22T00:00:00+08:00",
      "updated_at": "2026-04-22T00:00:00+08:00"
    },
    {
      "id": "R-013",
      "text": "所有回复必须使用专业、简洁的语气，避免过度承诺",
      "injection_points": [
        "compose"
      ],
      "priority": 3,
      "source": "manual",
      "enabled": true,
      "created_at": "2026-04-22T00:00:00+08:00",
      "updated_at": "2026-04-22T00:00:00+08:00"
    },
    {
      "id": "R-014",
      "text": "涉及加密资产时必须引用最新风险委员会决议",
