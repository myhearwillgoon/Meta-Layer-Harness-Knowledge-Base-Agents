        "email.analysis",
        "compose",
        "qa.answer"
      ],
      "priority": 5,
      "source": "manual",
      "enabled": true,
      "created_at": "2026-04-22T00:00:00+08:00",
      "updated_at": "2026-04-22T00:00:00+08:00"
    },
    {
      "id": "R-006",
      "text": "Call #1 路由决策：涉及监管/多方沟通/谈判的邮件使用 silra/qwen3.5-plus",
